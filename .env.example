# Copy to apps/api/.dev.vars for local `wrangler dev`, or set as Cloudflare Worker
# secrets / vars in production (wrangler secret put / [vars] in wrangler.jsonc).
# The agent routes LLM calls through the LiteLLM gateway:
LLM_GATEWAY_BASE_URL=
LLM_GATEWAY_API_KEY=
LLM_TIMEOUT_MS=120000

# === ACTIVE SCOPE (stripped to 4 sources + web_search) ===

# 1) App Store Connect — official API (owned-app data). From App Store Connect →
#    Users & Access → Integrations → App Store Connect API.
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY=            # contents of the .p8 (or path), keep out of git

# 2) Google Play — Android Publisher API (owned-app data). Service-account JSON
#    from Google Cloud Console (path or inlined JSON).
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# 3) Reddit — free OAuth app (reddit.com/prefs/apps → type "script").
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=hahaton:ai-ceo:v1 (by /u/your_username)

# 4) Bluesky — free open AT Protocol API. Public reads need no key; searchPosts
#    needs a free app password (bsky.app → Settings → App Passwords).
BLUESKY_IDENTIFIER=         # your-handle.bsky.social
BLUESKY_APP_PASSWORD=

# web_search uses ANTHROPIC_API_KEY above (enabled as a server tool in the SDK).

# Deferred — added later by other devs: Product Hunt, G2, Capterra, Kickstarter,
# Apptopia, data.ai, AppTweak, Appfigures, Crunchbase, Trustpilot, Similarweb,
# AppBrain (+ paid: AppMagic, Sensor Tower, MobileAction). BigIdeasDB: skipped.
# See docs/integrations-status.md.
