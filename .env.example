# Copy to apps/api/.env and fill in (the api service loads it via --env-file-if-exists).
# On Cloudflare these are provided as Worker secrets / vars instead (wrangler secret put / [vars]).
ANTHROPIC_API_KEY=sk-ant-...
PORT=3000

# Optional paid app-research APIs. Store real values only in local env files or
# Cloudflare secrets, never in git.
APPMAGIC_API_KEY=
SENSOR_TOWER_API_KEY=
APPTWEAK_API_KEY=
MOBILE_ACTION_API_KEY=

# Other optional sources already declared in @hahaton/integrations.
APPFIGURES_API_KEY=
APPTOPIA_API_KEY=
DATAAI_API_KEY=
CRUNCHBASE_API_KEY=
TRUSTPILOT_API_KEY=
SIMILARWEB_API_KEY=
APPBRAIN_API_KEY=
