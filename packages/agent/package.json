{
  "name": "@hahaton/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Idea → Business Plan agent pipeline: orchestrator + steps.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
