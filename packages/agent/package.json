  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hahaton/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0"
  }
}
