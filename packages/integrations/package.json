{
  "name": "@hahaton/integrations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "External API source + auth contracts, and the openapi-typescript codegen that types them.",
  "exports": {
    ".": "./src/index.ts",
    "./generated": "./src/generated/index.ts",
    "./handwritten": "./src/handwritten/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate:contracts": "tsx scripts/generate-contracts.ts",
    "clean": "rimraf .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "openapi-typescript": "^7.13.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
