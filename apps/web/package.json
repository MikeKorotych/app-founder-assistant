{
  "name": "@hahaton/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Next.js front-end for the AI CEO pipeline. Consumes @hahaton/api over HTTP; deployed to Cloudflare via OpenNext.",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "clean": "rimraf .next .open-next .turbo .wrangler *.tsbuildinfo"
  },
  "dependencies": {
    "@hahaton/contracts": "workspace:*",
    "@hahaton/ui": "workspace:*",
    "@hahaton/unit-economics": "workspace:*",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
