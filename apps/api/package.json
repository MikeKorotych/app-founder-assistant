{
  "name": "@hahaton/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hono Worker exposing the agent pipeline. Deployed to Cloudflare Workers.",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail",
    "clean": "rimraf dist .turbo .wrangler *.tsbuildinfo"
  },
  "dependencies": {
    "@hahaton/agent": "workspace:*",
    "@hahaton/contracts": "workspace:*",
    "@hahaton/db": "workspace:*",
    "@hahaton/llm": "workspace:*",
    "@hahaton/scout": "workspace:*",
    "@hahaton/search-intent": "workspace:*",
    "@hahaton/store": "workspace:*",
    "@hahaton/unit-economics": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
