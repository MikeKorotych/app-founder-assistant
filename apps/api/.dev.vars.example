# Copy to .dev.vars (gitignored) for local `wrangler dev`.
# These are Worker secrets — never commit the real values.
#
# In CI/production: LLM_GATEWAY_BASE_URL is a plain var in wrangler.jsonc and
# LLM_GATEWAY_API_KEY is injected via `wrangler secret put` (see
# .github/workflows/deploy.yml).

# LLM gateway — OpenAI-compatible. Default: OpenRouter (your account).
# Key: https://openrouter.ai/keys · models: https://openrouter.ai/models
# (Model ids live in packages/llm/src/catalog.ts — verify them on OpenRouter.)
LLM_GATEWAY_BASE_URL=https://openrouter.ai/api/v1
LLM_GATEWAY_API_KEY=sk-or-v1-replace-me
LLM_TIMEOUT_MS=120000

# Scout — competitor discovery sources (Worker secrets). Both optional: if unset,
# that source degrades to empty and Scout still runs on the others.
#   GOOGLE_SEARCH_API_KEY — SerpApi key (google_play engine) for Android results.
#                       Get it at serpapi.com → Dashboard → "Your API Key".
#   PRODUCTHUNT_TOKEN — Product Hunt API v2 developer token (Bearer).
#                       producthunt.com/v2/oauth/applications → Add app → Create Token.
GOOGLE_SEARCH_API_KEY=
PRODUCTHUNT_TOKEN=

# Appfigures — app market intelligence (Bearer = PAT). See docs/sources/appfigures.md.
# NOTE: current account is owned-apps-only (no connected apps); competitor/market
# data needs Partner API Access. Real values go in .dev.vars (gitignored).
APPFIGURES_PAT=
APPFIGURES_CLIENT_KEY=
APPFIGURES_SECRET_KEY=
